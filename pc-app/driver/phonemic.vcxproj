<?xml version="1.0" encoding="utf-8"?>
<!--
  PhoneMic virtual audio capture driver (KMDF + ACX).

  Requires the Windows Driver Kit (WDK) and its Visual Studio extension. If this
  project file drifts from your WDK version, the reliable fallback is: File >
  New > Project > "Kernel Mode Driver, Empty (KMDF)", then add driver.c,
  driver.h, and phonemic.inf and set the same properties shown below.
-->
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{B1C0A2D3-4E5F-6071-8293-A4B5C6D7E8F9}</ProjectGuid>
    <RootNamespace>phonemic</RootNamespace>
    <MinimumVisualStudioVersion>15.0</MinimumVisualStudioVersion>
    <Configuration>Debug</Configuration>
    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <TargetVersion>Windows10</TargetVersion>
    <DriverType>KMDF</DriverType>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <!-- ACX headers/libs ship with the WDK; ensure the ACX extension is enabled
         so acx.h and the ACX import libraries resolve. -->
    <EnableInf2cat>true</EnableInf2cat>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <PreprocessorDefinitions>_KERNEL_MODE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="driver.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="driver.h" />
    <ClInclude Include="..\ipc\ring.h" />
  </ItemGroup>
  <ItemGroup>
    <Inf Include="phonemic.inf" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
